---
/**
 * BaseLayout — <html> shell with full SEO <head>.
 * Used by all layout wrappers (MarketingLayout, BlogLayout, DocsLayout).
 */
import { getRelativeLocaleUrl } from 'astro:i18n';
import { r } from '@/i18n/r';
import { HREFLANG, OG_LOCALE, type Locale } from '@/i18n/locales';
import '../styles/global.css';

interface Props {
  seo: {
    title: any;
    description: any;
    ogImage?: string;
    jsonLd?: Record<string, unknown>;
  };
  lang: string;
  pageLocales?: string[];   // locales this page is actually built for
  slug?: string;            // e.g. "" for home, "pricing" for /pricing
}

const {
  seo,
  lang,
  pageLocales = ['en'],
  slug = '',
} = Astro.props;

const title       = r(seo.title, lang);
const description = r(seo.description, lang);
const ogImage     = seo.ogImage ? new URL(seo.ogImage, Astro.site).href : undefined;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// hreflang: only locales this page exists in
const hreflangLinks = pageLocales.map((locale) => ({
  hreflang: HREFLANG[locale as Locale] ?? locale,
  href: new URL(getRelativeLocaleUrl(locale, slug || '/'), Astro.site).href,
}));

const xDefaultHref = new URL(getRelativeLocaleUrl('en', slug || '/'), Astro.site).href;

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'StartMessaging',
  url: Astro.site?.href,
});

const webPageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: canonicalURL.href,
  inLanguage: HREFLANG[lang as Locale] ?? lang,
});
---

<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates -->
    {hreflangLinks.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={l.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:locale"      content={OG_LOCALE[lang as Locale] ?? lang} />
    {hreflangLinks
      .filter((l) => l.hreflang !== HREFLANG[lang as Locale])
      .map((l) => (
        <meta property="og:locale:alternate" content={l.hreflang.replace('-', '_')} />
      ))
    }
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width"  content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Sitemap discovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon (placeholder) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={orgSchema} />
    <script type="application/ld+json" set:html={webPageSchema} />
    {seo.jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
