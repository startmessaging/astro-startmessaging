---
/**
 * BaseLayout — <html> shell with full SEO <head>.
 * Country-routed model per ASTRO_COUNTRY_PLAN.md §11.
 * Supports dark mode via data-theme attribute + anti-FOUC inline script.
 *
 * SEO/GEO fixes per seo_geo_analysis_report.md:
 *  - Step 2a: canonical override via seo.canonical (for duplicate blog posts)
 *  - Step 2b: generic language hreflang fallbacks (pt→/br, es→/mx, id→/id, ar→/ae, tr→/tr)
 *  - Step 2c: optional <meta name="keywords"> for non-Google search engines
 */
import { r } from '@/i18n/r';
import {
  COUNTRY_CONFIG,
  HREFLANG,
  OG_LOCALE,
  ALL_COUNTRIES,
  urlPrefix,
  type Country,
} from '@/config/countries';
import CountryNotice from '@/components/CountryNotice.astro';
import '../styles/global.css';

interface Props {
  seo: {
    title: any;
    description: any;
    ogImage?: string;
    jsonLd?: any;
    /**
     * Optional canonical URL override (relative path, e.g. "/blog/my-post").
     * Used by BlogLayout for shared/duplicated posts (canonicalCountry frontmatter)
     * so the duplicate points its canonical tag to the master copy.
     */
    canonical?: string;
    /**
     * Optional keywords array. Output as <meta name="keywords"> for non-Google
     * search engines used in target markets (Yandex, Baidu, Naver, etc.).
     */
    keywords?: string[];
  };
  country: string;
  pageCountries?: string[];
  slug?: string;
  theme?: string;
}

const {
  seo,
  country,
  pageCountries = ALL_COUNTRIES as string[],
  slug = '',
  theme = 'sms',
} = Astro.props;

const c = country as Country;
const cfg = COUNTRY_CONFIG[c];
const lang = cfg?.lang ?? 'en';
const dir = cfg?.dir ?? 'ltr';

const title       = r(seo.title, c);
const description = r(seo.description, c);
const ogImage     = seo.ogImage ? new URL(seo.ogImage, Astro.site).href : undefined;

// Canonical: prefer explicit override (for duplicate blog posts), else self URL.
const canonicalURL = seo.canonical
  ? new URL(seo.canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

// hreflang: region-specific alternates for every country this page is built for
const hreflangLinks = pageCountries
  .filter((pc) => pc in COUNTRY_CONFIG)
  .map((pc) => {
    const prefix = urlPrefix(pc as Country);
    const pagePath = slug ? `${prefix}/${slug}` : (prefix || '/');
    return {
      hreflang: HREFLANG[pc as Country],
      href: new URL(pagePath, Astro.site).href,
    };
  });

// Generic language hreflang fallbacks (e.g. hreflang="pt" → /br).
// Catches users in markets outside our specific country targets (e.g. Portugal,
// Argentina) and routes them to the best matching language instead of x-default.
// Only emitted when the owning country is actually in pageCountries.
const genericHreflangLinks: { hreflang: string; href: string }[] = [];
const seenLanguages = new Set<string>();

// Preferred generic-language owners — order is authoritative (first match wins)
const genericLangOwner: Array<[string, Country]> = [
  ['en', 'in'],   // India  → canonical English
  ['pt', 'br'],   // Brazil → canonical Portuguese
  ['es', 'mx'],   // Mexico → canonical Spanish
  ['id', 'id'],   // Indonesia → canonical Indonesian
  ['ar', 'ae'],   // UAE    → canonical Arabic
  ['tr', 'tr'],   // Turkey → canonical Turkish
];

for (const [langCode, ownerCountry] of genericLangOwner) {
  if (!pageCountries.includes(ownerCountry)) continue;  // page not built for this country
  if (seenLanguages.has(langCode)) continue;             // already emitted

  const prefix = urlPrefix(ownerCountry);
  const pagePath = slug ? `${prefix}/${slug}` : (prefix || '/');
  genericHreflangLinks.push({
    hreflang: langCode,
    href: new URL(pagePath, Astro.site).href,
  });
  seenLanguages.add(langCode);
}

// x-default → India root (no prefix)
const xDefaultPath = slug ? `/${slug}` : '/';
const xDefaultHref = new URL(xDefaultPath, Astro.site).href;

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'StartMessaging',
  url: Astro.site?.href,
});

const webPageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: canonicalURL.href,
  inLanguage: HREFLANG[c] ?? lang,
});

// Anti-FOUC: inline script that sets theme before first paint
const themeScript = `(function(){try{var t=localStorage.getItem('sm-theme');if(t==='dark')document.documentElement.setAttribute('data-theme','dark');}catch(e){}})();`;
---

<html lang={lang} dir={dir} data-theme-brand={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Anti-FOUC: set theme before CSS loads -->
    <script is:inline set:html={themeScript} />

    <!-- Google Fonts: Inter (variable) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..800&display=swap" rel="stylesheet" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="country" content={cfg?.code ?? 'IN'} />
    {seo.keywords && seo.keywords.length > 0 && (
      <meta name="keywords" content={seo.keywords.join(', ')} />
    )}

    <!-- hreflang alternates: region-specific + generic language fallbacks -->
    {hreflangLinks.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={l.href} />
    ))}
    {genericHreflangLinks.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={l.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:locale"      content={OG_LOCALE[c] ?? lang} />
    {hreflangLinks
      .filter((l) => l.hreflang !== HREFLANG[c])
      .map((l) => (
        <meta property="og:locale:alternate" content={l.hreflang.replace('-', '_')} />
      ))
    }
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width"  content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Sitemap discovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={theme === 'whatsapp' ? '/favicon-wa.svg' : '/favicon.svg'} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" is:inline set:html={orgSchema} />
    <script type="application/ld+json" is:inline set:html={webPageSchema} />
    {seo.jsonLd && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(seo.jsonLd)} />
    )}
  </head>
  <body>
    <slot />
    <CountryNotice country={country} currentPath={Astro.url.pathname} />
  </body>
</html>
