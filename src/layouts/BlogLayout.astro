---
/**
 * BlogLayout — wraps individual blog posts.
 * Ported from startmessaging-astro: breadcrumbs, BlogHeader, prose, AuthorCard, sidebar TOC, RelatedPosts.
 * Per ASTRO_COUNTRY_PLAN.md §10.
 */
import MarketingLayout from './MarketingLayout.astro';
import BlogHeader from '@/components/blog/BlogHeader.astro';
import AuthorCard from '@/components/blog/AuthorCard.astro';
import RelatedPosts from '@/components/blog/RelatedPosts.astro';
import Breadcrumbs from '@/components/blog/Breadcrumbs.astro';
import TableOfContents from '@/components/blog/TableOfContents.astro';
import { urlPrefix, type Country } from '@/config/countries';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Match any files under src/assets/images
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png,gif,webp}');


interface TocEntry {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  frontmatter: {
    title: string;
    description: string;
    publishedAt: Date | string;
    updatedAt?: Date | string;
    category?: string;
    author?: string;
    tags?: string[];
    ogImage?: string;
    relatedSlugs?: string[];
    /**
     * When set, this post is a duplicate of a master post in another country.
     * Value = the country code of the master (e.g. 'in' means /blog/<slug> is master).
     * BlogLayout computes a canonical URL pointing to the master and passes it to BaseLayout.
     * Per seo_geo_analysis_report.md Step 3.
     */
    canonicalCountry?: string;
    /** SEO keywords from frontmatter — forwarded to <meta name="keywords"> via BaseLayout. */
    keywords?: string[];
    /** Optional featured blog image path (relative to public/), e.g. "/blog/images/hero.webp" */
    image?: string;
  };
  country: string;
  slug: string;
  /** countries that have a version of this post (for hreflang) */
  pageCountries: string[];
  headings?: TocEntry[];
}

const { frontmatter, country, slug, pageCountries, headings = [] } = Astro.props;
const c = country as Country;
const prefix = urlPrefix(c);
const blogHref = prefix ? `${prefix}/blog` : '/blog';

// Determine theme dynamically based on country and url pathname
let theme = 'sms';
if (country !== 'in') {
  theme = 'whatsapp';
} else {
  const path = Astro.url.pathname;
  const isWhatsappPath = path.includes('/whatsapp');
  theme = isWhatsappPath ? 'whatsapp' : 'sms';
}
const proseLinkColor = 'prose-a:text-primary hover:prose-a:text-primary-active';

// Step 3 (seo_geo_analysis_report.md): Compute canonical override for duplicate/shared posts.
// When frontmatter.canonicalCountry is set, this post is a copy of a master in another country.
// We build the path to the master so BaseLayout outputs the correct <link rel="canonical">.
let canonicalOverride: string | undefined;
if (frontmatter.canonicalCountry) {
  const canonicalPrefix = urlPrefix(frontmatter.canonicalCountry as Country);
  // India's canonical prefix is empty (root), all others have /xx prefix
  canonicalOverride = frontmatter.canonicalCountry === 'in'
    ? `/blog/${slug}`
    : `${canonicalPrefix}/blog/${slug}`;
}

// Resolve image asset dynamically if it exists in src/assets/images/blog/ or src/assets/images/
let imageSrcPath = '';
if (frontmatter.image) {
  if (frontmatter.image.startsWith('/blog/images/')) {
    imageSrcPath = frontmatter.image.replace(/^\/blog\/images\//, '/src/assets/images/blog/');
  } else if (frontmatter.image.startsWith('/images/')) {
    imageSrcPath = frontmatter.image.replace(/^\/images\//, '/src/assets/images/');
  }
}
const imageResolver = images[imageSrcPath];
const imageAsset = imageResolver ? (await imageResolver()).default : null;

// Compute dynamic blog post OG image URL when frontmatter does not define a custom static one
// Defaults to the optimized custom imageAsset if uploaded, then falls back to dynamic OG function
const computedOgImage = frontmatter.ogImage ?? imageAsset?.src ?? (prefix ? `/og${prefix}/blog/${slug}.png` : `/og/blog/${slug}.png`);



const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: new Date(frontmatter.publishedAt).toISOString(),
  ...(frontmatter.updatedAt
    ? { dateModified: new Date(frontmatter.updatedAt).toISOString() }
    : { dateModified: new Date(frontmatter.publishedAt).toISOString() }),
  author: {
    '@type': 'Person',
    name: frontmatter.author ?? 'StartMessaging Team',
  },
  publisher: {
    '@type': 'Organization',
    name: 'StartMessaging',
    url: 'https://startmessaging.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://startmessaging.com/favicon.svg'
    }
  },
  url: `https://startmessaging.com${prefix}/blog/${slug}`,
  image: new URL(computedOgImage, 'https://startmessaging.com').href
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://startmessaging.com${prefix || '/'}` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `https://startmessaging.com${blogHref}` },
    { '@type': 'ListItem', position: 3, name: frontmatter.title, item: `https://startmessaging.com${prefix}/blog/${slug}` },
  ],
};
---

<MarketingLayout
  seo={{
    title: `${frontmatter.title} | StartMessaging Blog`,
    description: frontmatter.description,
    ogImage: computedOgImage,
    ogType: 'article',
    jsonLd: [articleSchema, breadcrumbSchema],
    canonical: canonicalOverride,
    keywords: frontmatter.keywords,
  }}
  country={country}
  pageCountries={pageCountries}
  slug={`blog/${slug}`}
  theme={theme}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs
      items={[
        { label: 'Blog', href: blogHref },
        { label: frontmatter.title },
      ]}
      homeHref={prefix || '/'}
    />
    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12 mt-8">
      <article class="min-w-0">
        <BlogHeader
          post={{
            title: frontmatter.title,
            description: frontmatter.description,
            publishedAt: new Date(frontmatter.publishedAt),
            updatedAt: frontmatter.updatedAt ? new Date(frontmatter.updatedAt) : undefined,
            category: frontmatter.category ?? 'guides',
            author: frontmatter.author,
          }}
          country={country}
        />
        {imageAsset && (
          <Image
            src={imageAsset}
            alt={frontmatter.title}
            widths={[360, 540, 720, 960, 1200]}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 75vw, 900px"
            class="w-full h-auto rounded-lg mb-8 shadow-sm object-cover"
            loading="eager"
            decoding="async"
          />
        )}
        <div class:list={["prose prose-neutral dark:prose-invert max-w-none prose-headings:font-bold prose-code:before:content-none prose-code:after:content-none", proseLinkColor]}>
          <slot />
        </div>
        {frontmatter.author && <AuthorCard author={frontmatter.author} />}
      </article>
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
    {frontmatter.relatedSlugs && frontmatter.relatedSlugs.length > 0 && (
      <RelatedPosts slugs={frontmatter.relatedSlugs} currentSlug={slug} country={country} />
    )}
  </div>
</MarketingLayout>
