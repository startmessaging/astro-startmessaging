---
/**
 * MarketingLayout — wraps all marketing pages with nav + footer.
 * Country-routed model: no language switcher. Nav/footer driven by country.
 * Per ASTRO_COUNTRY_PLAN.md §6.
 */
import BaseLayout from './BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import AppIcon from '@/components/ui/AppIcon.astro';
import { urlPrefix, type Country } from '@/config/countries';
import {
  getFooterColumns,
  getFooterTagline,
  getFooterLegal,
} from '@/i18n/nav';
import Navbar from '@/components/Navbar.astro';

interface Props {
  seo: {
    title: any;
    description: any;
    ogImage?: string;
    jsonLd?: any;
    /** Canonical URL override — forwarded to BaseLayout for duplicate blog posts. */
    canonical?: string;
    /** Keywords array — forwarded to BaseLayout for <meta name="keywords">. */
    keywords?: string[];
  };
  country: string;
  pageCountries?: string[];
  slug?: string;
  theme?: string;
}

const { seo, country, pageCountries, slug } = Astro.props;

// Determine theme dynamically based on country and url pathname / page content
let theme = Astro.props.theme || 'sms';
if (country !== 'in') {
  theme = 'whatsapp';
} else {
  const path = Astro.url.pathname;
  const isWhatsappPath = path.includes('/whatsapp');
  theme = (theme === 'whatsapp' || isWhatsappPath) ? 'whatsapp' : 'sms';
}

const c = country as Country;
const prefix = urlPrefix(c);

const isWhatsapp = theme === 'whatsapp';
const logoTextClass = isWhatsapp ? 'gradient-text-wa inline-block' : 'gradient-text-primary inline-block';

const footerBgClass = isWhatsapp ? 'bg-surface-wa border-accent-wa/20' : 'bg-surface-card border-hairline';
const footerBorderClass = isWhatsapp ? 'border-accent-wa/20' : 'border-hairline';
const footerTextClass = isWhatsapp ? 'text-body' : 'text-muted';
const footerHoverTextClass = isWhatsapp ? 'hover:text-accent-wa' : 'hover:text-ink';
const footerIconHoverClass = isWhatsapp ? 'hover:text-accent-wa' : 'hover:text-primary';

const footerCols  = getFooterColumns(c);
const footerTagline = getFooterTagline(c);
const legal       = getFooterLegal(c);
const homeHref    = prefix || '/';
---

<BaseLayout {seo} {country} {pageCountries} {slug} {theme}>

  <!-- ─── Navigation ──────────────────────────────────────────────────── -->
  <Navbar country={country} currentPath={Astro.url.pathname} theme={theme} />

  <!-- ─── Page content ─────────────────────────────────────────────────── -->
  <main id="main-content">
    <slot />
  </main>

  <!-- ─── Footer ───────────────────────────────────────────────────────── -->
  <footer class:list={["border-t pt-[var(--spacing-xxl)] pb-[var(--spacing-section)]", footerBgClass]} id="main-footer">
    <Container>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 mb-12">

        <!-- Brand column -->
        <div class="col-span-1 sm:col-span-2 md:col-span-3 lg:col-span-1">
          <a href={homeHref} class="flex items-center gap-2 font-bold text-title-md text-ink mb-3">
            <AppIcon class="h-5 w-5" theme={theme} />
            <span>Start<span class:list={[logoTextClass]}>Messaging</span></span>
          </a>
          <p class:list={["text-body-sm max-w-sm leading-relaxed", footerTextClass]}>
            {footerTagline}
          </p>
        </div>

        <!-- Country-specific link columns -->
        {footerCols.map((col) => (
          <div>
            <h3 class="text-title-sm font-medium text-ink mb-3">
              {col.heading}
            </h3>
            <ul class="flex flex-col gap-2">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class:list={["text-body-sm transition-colors", footerTextClass, footerHoverTextClass]}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>

      <!-- Legal band -->
      <div class:list={["flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 border-t", footerBorderClass]}>
        <p class:list={["text-caption-sm col-span-2 sm:col-span-1", footerTextClass]}>
          {legal.copyright}
        </p>
        <div class:list={["flex items-center gap-4", footerTextClass]}>
          <!-- <a href="https://facebook.com/startmessaging" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a> -->
          <a href="https://instagram.com/startmessaging" target="_blank" rel="noopener noreferrer" class:list={["transition-colors", footerIconHoverClass]} aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://linkedin.com/company/startmessaging" target="_blank" rel="noopener noreferrer" class:list={["transition-colors", footerIconHoverClass]} aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a href="https://youtube.com/@startmessaging" target="_blank" rel="noopener noreferrer" class:list={["transition-colors", footerIconHoverClass]} aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17z"></path>
              <polygon points="10 15 15 12 10 9"></polygon>
            </svg>
          </a>
        </div>
      </div>

    </Container>
  </footer>

</BaseLayout>
