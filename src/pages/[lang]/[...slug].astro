---
// Non-English marketing pages: /pt-br/pricing  /pt-br/whatsapp  etc.
import { getCollection } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ComponentRenderer from '@/components/ComponentRenderer.astro';
import { ALL_LOCALES, DEFAULT_LOCALE } from '@/i18n/locales';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  return pages.flatMap((page) => {
    if (page.id === 'home') return []; // home handled by [lang]/index.astro

    const slug = page.id.replace(/\/index$/, '');
    const allowedLocales = (page.data.locales ?? ALL_LOCALES) as string[];
    const nonDefaultLocales = allowedLocales.filter((l) => l !== DEFAULT_LOCALE);

    return nonDefaultLocales.map((locale) => ({
      params: { lang: locale, slug },
      props: { page, lang: locale, pageLocales: allowedLocales },
    }));
  });
}

const { page, lang, pageLocales } = Astro.props;
const slug = Astro.params.slug ?? '';
---

<MarketingLayout
  seo={page.data.seo}
  lang={lang}
  pageLocales={pageLocales}
  slug={slug}
>
  {page.data.sections.map((section: any) => (
    <ComponentRenderer
      type={section.type}
      props={section.props}
      lang={lang}
      locales={section.locales}
    />
  ))}
</MarketingLayout>
