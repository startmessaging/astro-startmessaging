---
// English blog listing: /blog
import { getCollection } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Container from '@/components/ui/Container.astro';

const posts = await getCollection('blog');
const enPosts = posts
  .filter((p) => p.id.startsWith('en/'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const lang = 'en';
---

<MarketingLayout
  seo={{
    title: 'Blog — StartMessaging',
    description: 'Guides, tips, and updates on WhatsApp Business API and messaging.',
  }}
  lang={lang}
  pageLocales={['en']}
  slug="blog"
>
  <Container>
    <div class="py-16">
      <h1 class="text-display-md font-bold text-ink mb-4">Blog</h1>
      <p class="text-display-sm text-muted mb-12">
        Guides, tips, and updates on WhatsApp Business API and messaging.
      </p>

      <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {enPosts.map((post) => {
          const slug = post.id.replace(/^en\//, '');
          const dateStr = post.data.publishedAt.toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <li>
              <a
                href={`/blog/${slug}`}
                class="group block rounded-md border border-hairline bg-surface-soft overflow-hidden hover:shadow-card transition-shadow"
              >
                <div class="p-6">
                  {post.data.tags?.length && (
                    <div class="flex flex-wrap gap-2 mb-3">
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class="text-xs font-medium text-primary bg-primary-disabled px-2.5 py-0.5 rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <h2 class="text-title-md font-semibold text-ink group-hover:text-primary transition-colors mb-2 line-clamp-2">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-muted line-clamp-3 mb-4">
                    {post.data.description}
                  </p>
                  <time class="text-xs text-muted" datetime={post.data.publishedAt.toISOString()}>
                    {dateStr}
                  </time>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </Container>
</MarketingLayout>
