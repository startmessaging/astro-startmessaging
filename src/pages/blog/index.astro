---
/**
 * India blog listing: /blog
 * Style ported from startmessaging-astro blog index.
 * Features: centered header, category pills, featured hero card, BlogCard grid, CTA.
 */
import { getCollection } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Button from '@/components/ui/Button.astro';

const CATEGORY_LABELS: Record<string, string> = {
  tutorials: 'Tutorials',
  guides: 'Guides',
  comparisons: 'Comparisons',
  compliance: 'Compliance',
  'use-cases': 'Use Cases',
  business: 'Business',
};

const posts = await getCollection('blog');
const sorted = posts
  .filter((p) => p.id.startsWith('in/'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const [featured, ...rest] = sorted;
---

<MarketingLayout
  seo={{
    title: 'Blog — OTP API Guides & Updates | StartMessaging',
    description: `${sorted.length}+ guides and tutorials about OTP APIs, DLT registration, SMS delivery, and phone verification for Indian developers.`,
  }}
  country="in"
  pageCountries={['in']}
  slug="blog"
>
  <article>
    <!-- Hero header -->
    <section class="py-12 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-bold tracking-tight text-[var(--color-persian)] sm:text-5xl">Blog</h1>
          <p class="mt-4 text-lg text-[var(--color-persian)]/70">
            {sorted.length}+ guides and tutorials about OTP APIs, SMS delivery, and phone verification for Indian developers.
          </p>
        </div>

        <!-- Category pills -->
        <div class="mt-8 flex flex-wrap justify-center gap-2">
          <a href="/blog" class="rounded-full bg-[var(--color-persian)] px-4 py-2 text-sm font-medium text-white">
            All
          </a>
          {Object.entries(CATEGORY_LABELS).map(([cat, label]) => (
            <a
              href={`/blog/category/${cat}`}
              class="rounded-full bg-[var(--color-persian)]/10 px-4 py-2 text-sm font-medium text-[var(--color-persian)] hover:bg-[var(--color-persian)]/20 transition-colors"
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured post -->
    {featured && (
      <section class="pb-8 sm:pb-12">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <a
            href={`/blog/${featured.id.replace(/^in\//, '')}`}
            class="block rounded-2xl border border-[var(--color-persian)]/20 p-6 hover:border-[var(--color-persian)]/40 transition-colors sm:p-8 md:p-10"
          >
            <div class="grid gap-6 md:grid-cols-5 md:gap-10">
              <div class="md:col-span-3">
                <span class="inline-block rounded-full bg-[var(--color-persian)]/10 px-3 py-1 text-xs font-medium text-[var(--color-persian)]">
                  {CATEGORY_LABELS[featured.data.category] ?? featured.data.category}
                </span>
                <h2 class="mt-3 text-2xl font-bold tracking-tight text-[var(--color-persian)] sm:text-3xl">
                  {featured.data.title}
                </h2>
                <p class="mt-3 text-[var(--color-persian)]/70 sm:mt-4 sm:text-lg">
                  {featured.data.description}
                </p>
              </div>
              <div class="flex flex-col justify-end md:col-span-2">
                <div class="text-sm text-[var(--color-persian)]/50">
                  <span class="font-medium text-[var(--color-persian)]/70">{featured.data.author}</span>
                  <span class="mx-2">·</span>
                  <time datetime={featured.data.publishedAt.toISOString()}>
                    {featured.data.publishedAt.toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                </div>
              </div>
            </div>
          </a>
        </div>
      </section>
    )}

    <!-- More articles grid -->
    <section class="pb-12 sm:pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        {rest.length > 0 && (
          <div class="mb-6 flex items-center gap-3 sm:mb-8">
            <h2 class="text-xl font-semibold tracking-tight text-[var(--color-persian)] sm:text-2xl">More Articles</h2>
            <span class="rounded-full bg-[var(--color-persian)]/10 px-2.5 py-0.5 text-xs font-medium text-[var(--color-persian)]/70">
              {rest.length}
            </span>
          </div>
        )}
        <div class="grid gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
          {rest.map((post) => <BlogCard post={post} country="in" />)}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-[var(--color-surface-soft)] py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
            Ready to Start Building?
          </h2>
          <p class="mt-4 text-lg text-muted">
            Skip the blog and go straight to sending OTPs. Sign up and integrate in 5 minutes.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <Button href="https://app.startmessaging.com/signup" variant="primary" size="md">
              Start for Free →
            </Button>
            <Button href="/otp-api" variant="secondary" size="md">
              View API Docs
            </Button>
          </div>
        </div>
      </div>
    </section>
  </article>
</MarketingLayout>
