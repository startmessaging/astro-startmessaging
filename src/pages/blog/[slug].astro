---
// India/English blog posts: /blog/whatsapp-business-api-guide
// Per ASTRO_COUNTRY_PLAN.md §10.
import { getCollection, render } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // India posts are under the 'in/' directory
  const inPosts = posts.filter((p) => p.id.startsWith('in/'));

  return inPosts.map((post) => {
    const slug = post.id.replace(/^in\//, '');

    // Find which other countries have this same slug
    const pageCountries = posts
      .filter((p) => p.id.endsWith(`/${slug}`))
      .map((p) => p.id.split('/')[0]);

    return {
      params: { slug },
      props: { post, pageCountries },
    };
  });
}

const { post, pageCountries } = Astro.props;
const { Content, headings } = await render(post);
const slug = Astro.params.slug;
---

<BlogLayout
  frontmatter={post.data}
  country="in"
  slug={slug}
  pageCountries={pageCountries}
  headings={headings}
>
  <Content />
</BlogLayout>
