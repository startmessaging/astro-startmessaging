---
/**
 * India home page: /
 * Per ASTRO_COUNTRY_PLAN.md §3.
 */
import { getEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ComponentRenderer from '@/components/ComponentRenderer.astro';
import { ALL_COUNTRIES } from '@/config/countries';

const country = 'in';
const page = await getEntry('pages', 'home');

if (!page) return Astro.redirect('/404');

const pageCountries = (page.data.countries ?? ALL_COUNTRIES) as string[];
const pageTheme = page.data.theme ?? 'sms';
---

<MarketingLayout
  seo={page.data.seo}
  country={country}
  pageCountries={pageCountries}
  slug=""
  theme={pageTheme}
>
  {page.data.sections.map((section) => (
    <ComponentRenderer
      type={section.type}
      props={section.props}
      country={country}
      countries={section.countries}
      theme={section.theme ?? pageTheme}
    />
  ))}
</MarketingLayout>
