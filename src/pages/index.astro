---
import { getEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ComponentRenderer from '@/components/ComponentRenderer.astro';
import { ALL_LOCALES } from '@/i18n/locales';

const lang = 'en';
const page = await getEntry('pages', 'home');

if (!page) return Astro.redirect('/404');

const pageLocales = (page.data.locales ?? ALL_LOCALES) as string[];
---

<MarketingLayout
  seo={page.data.seo}
  lang={lang}
  pageLocales={pageLocales}
  slug=""
>
  {page.data.sections.map((section) => (
    <ComponentRenderer
      type={section.type}
      props={section.props}
      lang={lang}
      locales={section.locales}
    />
  ))}
</MarketingLayout>
