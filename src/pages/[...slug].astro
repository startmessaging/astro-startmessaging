---
/**
 * India non-home marketing pages: /pricing  /whatsapp  /whatsapp/broadcast  etc.
 * Per ASTRO_COUNTRY_PLAN.md §3.
 */
import { getCollection } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ComponentRenderer from '@/components/ComponentRenderer.astro';
import { ALL_COUNTRIES, DEFAULT_COUNTRY } from '@/config/countries';
import { buildService } from '@/lib/jsonld';
import { r } from '@/i18n/r';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  return pages
    .filter((page) => {
      // Skip home — handled by index.astro
      // Skip pages not available in India
      const countries = (page.data.countries ?? ALL_COUNTRIES) as string[];
      return page.id !== 'home' && countries.includes(DEFAULT_COUNTRY);
    })
    .map((page) => {
      // "whatsapp/index" → "whatsapp"  |  "pricing" → "pricing"
      const slug = page.id.replace(/\/index$/, '');
      const countries = (page.data.countries ?? ALL_COUNTRIES) as string[];
      return {
        params: { slug },
        props: { page, country: DEFAULT_COUNTRY, pageCountries: countries },
      };
    });
}

const { page, country, pageCountries } = Astro.props;
const slug = Astro.params.slug ?? '';
const pageTheme = page.data.theme ?? 'sms';

// Inject Service schema for WhatsApp and SMS product pages
const isServicePage = slug.startsWith('whatsapp') || slug.startsWith('sms');
const serviceType = slug.startsWith('whatsapp') ? 'WhatsApp Business API' : 'SMS API';
const seoWithSchema = isServicePage
  ? {
      ...page.data.seo,
      jsonLd: buildService(
        r(page.data.seo.title, country),
        serviceType,
        r(page.data.seo.description, country),
        `https://startmessaging.com/${slug}`,
        pageCountries as any[]
      ),
    }
  : page.data.seo;
---

<MarketingLayout
  seo={seoWithSchema}
  country={country}
  pageCountries={pageCountries}
  slug={slug}
  theme={pageTheme}
>
  {page.data.sections.map((section: any) => (
    <ComponentRenderer
      type={section.type}
      props={section.props}
      country={country}
      countries={section.countries}
      theme={section.theme ?? pageTheme}
    />
  ))}
</MarketingLayout>
