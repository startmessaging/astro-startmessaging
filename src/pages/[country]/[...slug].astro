---
/**
 * Non-India country non-home pages: /br/pricing  /mx/whatsapp  /ae/features  etc.
 * Per ASTRO_COUNTRY_PLAN.md §3.
 */
import { getCollection } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ComponentRenderer from '@/components/ComponentRenderer.astro';
import { ALL_COUNTRIES, DEFAULT_COUNTRY, type Country } from '@/config/countries';
import { buildService } from '@/lib/jsonld';
import { r } from '@/i18n/r';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  return pages.flatMap((page) => {
    if (page.id === 'home') return []; // home handled by [country]/index.astro

    const slug = page.id.replace(/\/index$/, '');
    // page.data.countries restricts which countries build this page (e.g. SMS = ['in'])
    const allowedCountries = (page.data.countries ?? ALL_COUNTRIES) as string[];
    const nonDefaultCountries = allowedCountries.filter((c) => c !== DEFAULT_COUNTRY);

    return nonDefaultCountries.map((c) => ({
      params: { country: c, slug },
      props: { page, country: c, pageCountries: allowedCountries },
    }));
  });
}

const { page, country, pageCountries } = Astro.props;
const slug = Astro.params.slug ?? '';
const pageTheme = page.data.theme ?? 'sms';

// Inject Service schema for WhatsApp and SMS product pages
const isServicePage = slug.startsWith('whatsapp') || slug.startsWith('sms');
const serviceType = slug.startsWith('whatsapp') ? 'WhatsApp Business API' : 'SMS API';
const seoWithSchema = isServicePage
  ? {
      ...page.data.seo,
      jsonLd: buildService(
        r(page.data.seo.title, country as Country),
        serviceType,
        r(page.data.seo.description, country as Country),
        `https://startmessaging.com/${country}/${slug}`,
        pageCountries as Country[]
      ),
    }
  : page.data.seo;
---

<MarketingLayout
  seo={seoWithSchema}
  country={country}
  pageCountries={pageCountries}
  slug={slug}
  theme={pageTheme}
>
  {page.data.sections.map((section: any) => (
    <ComponentRenderer
      type={section.type}
      props={section.props}
      country={country}
      countries={section.countries}
      theme={section.theme ?? pageTheme}
    />
  ))}
</MarketingLayout>
