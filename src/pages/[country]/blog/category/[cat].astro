---
/**
 * Country blog category listing: /br/blog/category/guides
 * Per ASTRO_COUNTRY_PLAN.md §3.
 * Style matches India blog category page: centered header, category pills, BlogCard grid, CTA.
 */
import { getCollection } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Button from '@/components/ui/Button.astro';
import { HREFLANG, type Country } from '@/config/countries';

export async function getStaticPaths() {
  const CATEGORIES = ['tutorials', 'guides', 'comparisons', 'compliance', 'use-cases', 'business'];
  const posts = await getCollection('blog');

  // Find which non-India countries have posts
  const countriesWithPosts = new Set(
    posts
      .filter((p) => !p.id.startsWith('in/'))
      .map((p) => p.id.split('/')[0])
  );

  const paths: { params: { country: string; cat: string } }[] = [];
  for (const country of countriesWithPosts) {
    for (const cat of CATEGORIES) {
      paths.push({ params: { country, cat } });
    }
  }
  return paths;
}

const { country, cat } = Astro.params;
const c = country as Country;
const posts = await getCollection('blog');

const catPosts = posts
  .filter((p) => p.id.startsWith(`${country}/`) && p.data.category === cat)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const CATEGORY_LABELS: Record<string, Record<string, string>> = {
  tutorials:   { en: 'Tutorials',   pt: 'Tutoriais',     es: 'Tutoriales',    id: 'Tutorial',     ar: 'دروس',         tr: 'Eğitimler' },
  guides:      { en: 'Guides',      pt: 'Guias',         es: 'Guías',         id: 'Panduan',      ar: 'أدلة',          tr: 'Rehberler' },
  comparisons: { en: 'Comparisons', pt: 'Comparações',   es: 'Comparaciones', id: 'Perbandingan', ar: 'مقارنات',       tr: 'Karşılaştırmalar' },
  compliance:  { en: 'Compliance',  pt: 'Conformidade',  es: 'Cumplimiento',  id: 'Kepatuhan',    ar: 'الامتثال',      tr: 'Uyumluluk' },
  'use-cases': { en: 'Use Cases',   pt: 'Casos de Uso',  es: 'Casos de Uso',  id: 'Kasus Penggunaan', ar: 'حالات الاستخدام', tr: 'Kullanım Senaryoları' },
  business:    { en: 'Business',    pt: 'Negócios',      es: 'Negocios',      id: 'Bisnis',       ar: 'الأعمال',       tr: 'İş' },
};

const ALL_LABEL: Record<string, string> = {
  en: 'All', pt: 'Todos', es: 'Todos', id: 'Semua', ar: 'الكل', tr: 'Tümü',
};

const lang = (HREFLANG[c] ?? 'en-IN').split('-')[0];
const catLabel = CATEGORY_LABELS[cat!]?.[lang] ?? CATEGORY_LABELS[cat!]?.en ?? cat;
const allLabel = ALL_LABEL[lang] ?? ALL_LABEL.en;
---

<MarketingLayout
  seo={{
    title: `${catLabel} — Blog — StartMessaging`,
    description: `Browse ${catPosts.length} ${catLabel.toLowerCase()} articles on StartMessaging's blog.`,
    noindex: true,
  }}
  country={country!}
  pageCountries={[country!]}
  slug={`blog/category/${cat!}`}
>
  <article>
    <!-- Hero header -->
    <section class="py-12 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-medium text-primary/60 mb-2">
            <a href={`/${country}/blog`} class="hover:text-primary">Blog</a> /
          </p>
          <h1 class="text-4xl font-bold tracking-tight text-primary sm:text-5xl">{catLabel}</h1>
          <p class="mt-4 text-lg text-primary/70">{catPosts.length} {catPosts.length !== 1 ? 'articles' : 'article'}</p>
        </div>

        <!-- Category pills -->
        <div class="mt-8 flex flex-wrap justify-center gap-2">
          <a href={`/${country}/blog`} class="rounded-full bg-primary/10 px-4 py-2 text-sm font-medium text-primary hover:bg-primary/20 transition-colors">
            {allLabel}
          </a>
          {Object.entries(CATEGORY_LABELS).map(([slug, labels]) => (
            <a
              href={`/${country}/blog/category/${slug}`}
              class={`rounded-full px-4 py-2 text-sm font-medium transition-colors ${slug === cat ? 'bg-primary text-white' : 'bg-primary/10 text-primary hover:bg-primary/20'}`}
            >
              {labels[lang] ?? labels.en}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Articles grid -->
    <section class="pb-12 sm:pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        {catPosts.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
            {catPosts.map((post) => <BlogCard post={post} country={country} />)}
          </div>
        ) : (
          <p class="text-center text-primary/60 py-16">No articles in this category yet.</p>
        )}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-[var(--color-surface-soft)] py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
            Ready to Start Building?
          </h2>
          <p class="mt-4 text-lg text-muted">
            Skip the blog and go straight to sending messages. Sign up and integrate in 5 minutes.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <Button href="https://app.startmessaging.com/signup" variant="primary" size="md">
              Start for Free →
            </Button>
            <Button href={`/${country}/pricing`} variant="secondary" size="md">
              View Pricing
            </Button>
          </div>
        </div>
      </div>
    </section>
  </article>
</MarketingLayout>
