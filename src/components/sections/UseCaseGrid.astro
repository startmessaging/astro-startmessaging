---
/**
 * UseCaseGrid — Grid of use-case cards with icons and links.
 *
 * Example JSON:
 * {
 *   "type": "useCaseGrid",
 *   "props": {
 *     "badge":   { "en": "Use Cases" },
 *     "heading": { "en": "Built for Every Business Need" },
 *     "cases": [
 *       {
 *         "icon": "cart",
 *         "title": { "en": "E-commerce" },
 *         "description": { "en": "Abandoned cart, order updates..." },
 *         "href": "/use-cases/ecommerce"
 *       }
 *     ]
 *   }
 * }
 */
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Heading from '@/components/ui/Heading.astro';
import Text from '@/components/ui/Text.astro';
import Badge from '@/components/ui/Badge.astro';
import { r } from '@/i18n/r';

const { badge, heading, subheading, cases = [], country, theme = 'sms' } = Astro.props;

const isWhatsapp = theme === 'whatsapp';
const hoverBorderClass = isWhatsapp
  ? 'hover:border-accent-wa/30 hover:shadow-glow-wa hover:-translate-y-0.5'
  : 'hover:border-primary/30 hover:shadow-glow-primary hover:-translate-y-0.5';
const textColorClass = isWhatsapp ? 'text-accent-wa' : 'text-primary';
const groupHoverTextClass = isWhatsapp ? 'group-hover:text-accent-wa' : 'group-hover:text-primary';
const cardBgClass = isWhatsapp ? 'bg-white/60 border border-accent-wa/10 shadow-sm' : 'bg-surface-card border border-hairline shadow-sm';

const caseIcons: Record<string, string> = {
  cart:     `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>`,
  headset: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>`,
  megaphone: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  bell:    `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  lock:    `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
};

const count = cases.length;
const gridCols = count === 4 ? 'sm:grid-cols-2 lg:grid-cols-4 max-w-6xl mx-auto' : 'sm:grid-cols-2 lg:grid-cols-3';
---

<Section theme={theme}>
  <Container>
    {(badge || heading || subheading) && (
      <div class="mb-12 flex flex-col items-center text-center gap-4">
        {badge    && <Badge tone="muted">{r(badge, country)}</Badge>}
        {heading  && <Heading as="h2">{r(heading, country)}</Heading>}
        {subheading && <Text tone="muted" class="max-w-2xl">{r(subheading, country)}</Text>}
      </div>
    )}

    <div class={`grid grid-cols-1 gap-6 ${gridCols}`}>
      {cases.map((uc: any) => (
        <a
          href={uc.href}
          class:list={["group flex flex-col gap-4 p-6 rounded-lg transition-all duration-300", cardBgClass, hoverBorderClass]}
        >
          {uc.icon && caseIcons[uc.icon] && (
            <div class:list={["w-10 h-10 group-hover:scale-110 transition-transform", textColorClass]} set:html={caseIcons[uc.icon]} />
          )}
          <div>
            <Heading as="h3" size="title-md" class:list={["mb-2 transition-colors", groupHoverTextClass]}>
              {r(uc.title, country)}
            </Heading>
            <Text size="body-sm" tone="muted">
              {r(uc.description, country)}
            </Text>
          </div>
          <span class:list={["text-button-sm font-medium mt-auto", textColorClass]}>
            {r(uc.ctaLabel || { en: 'Learn more' }, country)} →
          </span>
        </a>
      ))}
    </div>
  </Container>
</Section>
