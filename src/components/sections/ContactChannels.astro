---
/**
 * ContactChannels — Direct contact info cards (email, phone, WhatsApp).
 * No form — direct email, call, and WhatsApp support per user request.
 *
 * Example JSON:
 * {
 *   "type": "contactChannels",
 *   "props": {
 *     "badge":   { "en": "Reach Us" },
 *     "heading": { "en": "Get in Touch Directly" },
 *     "channels": [
 *       { "type": "email", "value": "startmessagingdotcom@gmail.com", "label": { "en": "Email Us" } },
 *       { "type": "phone", "value": "+916376383348", "label": { "en": "Call Us" } },
 *       { "type": "whatsapp", "value": "+916376383348", "label": { "en": "WhatsApp Support" } }
 *     ]
 *   }
 * }
 */
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Heading from '@/components/ui/Heading.astro';
import Text from '@/components/ui/Text.astro';
import Badge from '@/components/ui/Badge.astro';
import { r } from '@/i18n/r';

const { badge, heading, subheading, channels = [], country, theme = 'sms' } = Astro.props;

const isWhatsappTheme = theme === 'whatsapp';
const cardBgClass = isWhatsappTheme ? 'bg-white/60 border border-accent-wa/10 shadow-sm' : 'bg-surface-card border border-hairline shadow-sm';

const channelIcons: Record<string, string> = {
  email: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  phone: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 01-4.243-1.214l-.304-.18-3.154.827.842-3.074-.197-.314A8 8 0 1112 20z"/></svg>`,
};

function getHref(type: string, value: string): string {
  if (type === 'email') return `mailto:${value}`;
  if (type === 'phone') return `tel:${value}`;
  if (type === 'whatsapp') return `https://wa.me/${value.replace(/[^0-9]/g, '')}`;
  return '#';
}
---

<Section theme={theme}>
  <Container>
    {(badge || heading || subheading) && (
      <div class="mb-12 flex flex-col items-center text-center gap-4">
        {badge    && <Badge tone="muted">{r(badge, country)}</Badge>}
        {heading  && <Heading as="h2">{r(heading, country)}</Heading>}
        {subheading && <Text tone="muted" class="max-w-2xl">{r(subheading, country)}</Text>}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {channels.map((ch: any) => {
        const isWa = ch.type === 'whatsapp' || isWhatsappTheme;
        const borderClass = isWa
          ? 'hover:border-accent-wa/30 hover:shadow-glow-wa hover:-translate-y-0.5'
          : 'hover:border-primary/30 hover:shadow-glow-primary hover:-translate-y-0.5';
        const iconColor = isWa ? 'text-accent-wa' : 'text-primary';
        const textHoverColorClass = isWa ? 'group-hover:text-accent-wa' : 'group-hover:text-primary';

        return (
          <a
            href={getHref(ch.type, ch.value)}
            target={ch.type === 'whatsapp' ? '_blank' : undefined}
            rel={ch.type === 'whatsapp' ? 'noopener noreferrer' : undefined}
            class:list={[
              'group flex flex-col items-center text-center gap-4 p-8 rounded-lg transition-all duration-300',
              cardBgClass,
              borderClass,
            ]}
          >
            {channelIcons[ch.type] && (
              <div class:list={['w-12 h-12 group-hover:scale-110 transition-transform', iconColor]} set:html={channelIcons[ch.type]} />
            )}
            <div>
              <Heading as="h3" size="title-md" class:list={["mb-1 transition-colors", textHoverColorClass]}>
                {r(ch.label, country)}
              </Heading>
              <Text size="body-sm" tone="muted">
                {ch.value}
              </Text>
              {ch.description && (
                <Text size="body-sm" tone="muted" class="mt-2">
                  {r(ch.description, country)}
                </Text>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </Container>
</Section>
