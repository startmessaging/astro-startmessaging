---
/**
 * ComingSoon — placeholder for pages not yet built.
 *
 * Example JSON:
 * { "type": "comingSoon", "props": { "title": { "en": "Pricing" } } }
 */
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Heading from '@/components/ui/Heading.astro';
import Text from '@/components/ui/Text.astro';
import Button from '@/components/ui/Button.astro';
import { r } from '@/i18n/r';
import { t } from '@/i18n/t';
import { urlPrefix, type Country } from '@/config/countries';

const { title, country, theme } = Astro.props;
let resolvedTheme = theme || 'sms';
if (country !== 'in') {
  resolvedTheme = 'whatsapp';
} else {
  const path = Astro.url.pathname;
  const isWhatsappPath = path.includes('/whatsapp');
  resolvedTheme = (resolvedTheme === 'whatsapp' || isWhatsappPath) ? 'whatsapp' : 'sms';
}
const isWhatsapp = resolvedTheme === 'whatsapp';
const prefix = urlPrefix(country as Country);
const homeHref = prefix || '/';
const isPt = country === 'br';

const iconBgClass = isWhatsapp ? 'bg-accent-wa/10 text-accent-wa' : 'bg-primary-disabled text-primary';
const btnClass = isWhatsapp ? 'hover:!bg-accent-wa/[0.06] !border-accent-wa/30 !text-accent-wa' : '';
---

<Section theme={resolvedTheme}>
  <Container>
    <div class="flex flex-col items-center justify-center text-center py-24 gap-6 min-h-[60vh]">

      <!-- Icon -->
      <div class:list={["w-16 h-16 rounded-full flex items-center justify-center", iconBgClass]}>
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>

      {title && (
        <Text size="caption" tone="muted" class="uppercase tracking-widest">
          {r(title, country)}
        </Text>
      )}

      <Heading as="h1" size="display-lg">
        {isPt ? 'Em breve' : 'Coming Soon'}
      </Heading>

      <Text tone="muted" class="max-w-sm">
        {isPt
          ? 'Estamos trabalhando nesta página. Volte em breve.'
          : "We're building this page. Check back soon."}
      </Text>

      <Button href={homeHref} variant="secondary" size="sm" class={btnClass}>
        {t('nav.home', country)}
      </Button>

    </div>
  </Container>
</Section>
