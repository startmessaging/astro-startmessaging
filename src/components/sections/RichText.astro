---
/**
 * RichText — Freeform rich-text content section.
 *
 * Example JSON:
 * {
 *   "type": "richText",
 *   "props": {
 *     "heading": { "en": "Our Mission" },
 *     "body":    { "en": "<p>StartMessaging was founded...</p>" }
 *   }
 * }
 */
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import Heading from '@/components/ui/Heading.astro';
import Badge from '@/components/ui/Badge.astro';
import Text from '@/components/ui/Text.astro';
import { r } from '@/i18n/r';

const { badge, heading, subheading, body, country, theme } = Astro.props;
const isWhatsapp = theme === 'whatsapp';
---

<Section theme={theme}>
  <Container>
    {(badge || heading || subheading) && (
      <div class="mb-10 flex flex-col items-center text-center gap-4">
        {badge    && <Badge tone="muted">{r(badge, country)}</Badge>}
        {heading  && <Heading as="h2">{r(heading, country)}</Heading>}
        {subheading && <Text tone="muted" class="max-w-2xl">{r(subheading, country)}</Text>}
      </div>
    )}

    {body && (
      <div
        class:list={[
          "max-w-3xl mx-auto prose-custom text-body leading-relaxed [&_h2]:text-display-xs [&_h2]:font-bold [&_h2]:text-ink [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:text-title-lg [&_h3]:font-semibold [&_h3]:text-ink [&_h3]:mt-8 [&_h3]:mb-3 [&_p]:mb-4 [&_p]:text-body-md [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:flex [&_ul]:flex-col [&_ul]:gap-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol]:flex [&_ol]:flex-col [&_ol]:gap-2 [&_li]:text-body-sm [&_strong]:font-semibold [&_strong]:text-ink [&_blockquote]:border-l-4 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-muted",
          isWhatsapp
            ? "[&_a]:text-accent-wa [&_a]:underline [&_a]:hover:text-accent-wa-hover [&_blockquote]:border-accent-wa/30"
            : "[&_a]:text-primary [&_a]:underline [&_a]:hover:text-primary-active [&_blockquote]:border-primary/30"
        ]}
        set:html={r(body, country)}
      />
    )}
  </Container>
</Section>
