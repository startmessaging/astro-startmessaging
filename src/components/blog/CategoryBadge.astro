---
/**
 * CategoryBadge — pill badge showing the blog post category.
 * Ported from startmessaging-astro with same visual style.
 */
interface Props {
  category: string;
  href?: string;
}

const { category, href } = Astro.props;

const labels: Record<string, string> = {
  tutorials: 'Tutorials',
  guides: 'Guides',
  comparisons: 'Comparisons',
  compliance: 'Compliance',
  'use-cases': 'Use Cases',
  business: 'Business',
  security: 'Security',
};

const label = labels[category] ?? category;
---

{href ? (
  <a
    href={href}
    class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-persian/10 text-persian hover:bg-persian/20 transition-colors"
  >
    {label}
  </a>
) : (
  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-persian/10 text-persian">
    {label}
  </span>
)}

<style>
  .bg-persian\/10 { background-color: rgba(39, 24, 126, 0.10); }
  .bg-persian\/20 { background-color: rgba(39, 24, 126, 0.20); }
  .text-persian { color: var(--color-persian); }
</style>
