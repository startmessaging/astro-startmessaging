---
/**
 * CategoryBadge — pill badge showing the blog post category.
 * Ported from startmessaging-astro with same visual style.
 */
interface Props {
  category: string;
  href?: string;
}

const { category, href } = Astro.props;

const labels: Record<string, string> = {
  tutorials: 'Tutorials',
  guides: 'Guides',
  comparisons: 'Comparisons',
  compliance: 'Compliance',
  'use-cases': 'Use Cases',
  business: 'Business',
  security: 'Security',
};

const label = labels[category] ?? category;
---

{href ? (
  <a
    href={href}
    class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium badge-theme hover:badge-theme-hover transition-colors"
  >
    {label}
  </a>
) : (
  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium badge-theme">
    {label}
  </span>
)}

<style>
  .badge-theme {
    background-color: var(--color-hairline);
    color: var(--color-primary);
  }
  .badge-theme-hover:hover {
    background-color: var(--color-border-strong);
  }
</style>
