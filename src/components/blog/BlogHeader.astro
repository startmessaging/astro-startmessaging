---
/**
 * BlogHeader — post header with category badge, title, description, author + date.
 * Ported from startmessaging-astro.
 */
import CategoryBadge from './CategoryBadge.astro';
import { HREFLANG, type Country } from '@/config/countries';

interface Props {
  post: {
    title: string;
    description: string;
    publishedAt: Date;
    category: string;
    author?: string;
  };
  country?: string;
}

const { post, country = 'in' } = Astro.props;
const locale = HREFLANG[country as Country] ?? 'en-US';
---

<header class="mb-8">
  <CategoryBadge category={post.category} />
  <h1 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl">
    {post.title}
  </h1>
  <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">{post.description}</p>
  <div class="mt-4 flex items-center gap-4 text-sm text-gray-400 dark:text-gray-500">
    {post.author && <span>{post.author}</span>}
    {post.author && <span>·</span>}
    <time datetime={post.publishedAt.toISOString()}>
      {post.publishedAt.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>
</header>
