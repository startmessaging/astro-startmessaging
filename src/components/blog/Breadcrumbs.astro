---
/**
 * Breadcrumbs — lightweight breadcrumb nav.
 * Ported from startmessaging-astro.
 */
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  homeHref?: string;
}

const { items, homeHref = '/' } = Astro.props;
---

<nav aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-gray-500 dark:text-gray-400">
    <li>
      <a href={homeHref} class="hover:text-primary">Home</a>
    </li>
    {items.map((item) => (
      <li class="flex items-center gap-1">
        <span aria-hidden="true">/</span>
        {item.href ? (
          <a href={item.href} class="hover:text-primary">{item.label}</a>
        ) : (
          <span class="text-gray-900 dark:text-gray-100 font-medium" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
