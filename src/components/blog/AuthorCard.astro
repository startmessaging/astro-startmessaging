---
/**
 * AuthorCard — author attribution at the bottom of blog posts.
 * Ported from startmessaging-astro.
 */
interface Props {
  author: string;
}

const { author } = Astro.props;
---

<div class="mt-12 border-t border-gray-200 dark:border-gray-800 pt-6 flex items-center gap-4">
  <div class="w-10 h-10 rounded-full bg-[var(--color-persian)]/10 flex items-center justify-center text-[var(--color-persian)] font-semibold text-sm">
    {author.charAt(0)}
  </div>
  <div>
    <p class="text-sm font-medium text-gray-900 dark:text-gray-100">{author}</p>
    <p class="text-xs text-gray-500 dark:text-gray-400">StartMessaging Team</p>
  </div>
</div>
