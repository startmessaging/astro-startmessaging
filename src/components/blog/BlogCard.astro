---
/**
 * BlogCard — article card for blog listing grids.
 * Ported from startmessaging-astro with same visual style.
 */
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      publishedAt: Date;
      category: string;
      author?: string;
    };
  };
  country?: string;
}

const { post, country = 'in' } = Astro.props;
const { title, description, publishedAt, category } = post.data;
const slug = post.id.replace(/^[a-z]{2}\//, '');
const href = country === 'in' ? `/blog/${slug}` : `/${country}/blog/${slug}`;
---

<article class="flex flex-col rounded-xl border border-gray-200 dark:border-gray-800 p-5 hover:border-[var(--color-persian)]/40 transition-colors">
  <CategoryBadge category={category} />
  <h3 class="mt-3 text-base font-semibold text-gray-900 dark:text-gray-100 line-clamp-2">
    <a href={href} class="hover:text-[var(--color-persian)]">{title}</a>
  </h3>
  <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 line-clamp-2 flex-1">{description}</p>
  <div class="mt-4 flex items-center justify-between text-xs text-gray-400">
    <time datetime={publishedAt.toISOString()}>
      {publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
    </time>
    <a href={href} class="text-[var(--color-persian)] font-medium hover:underline">Read more →</a>
  </div>
</article>
