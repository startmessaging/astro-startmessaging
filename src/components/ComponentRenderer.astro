---
/**
 * Recursive component dispatcher.
 * Reads `type` from props, looks it up in componentMap, renders it.
 * Handles locale restriction via optional `locales[]` on each section.
 *
 * Usage:
 *   <ComponentRenderer type="hero" props={section.props} lang={lang} locales={section.locales} />
 */
import { componentMap } from './componentMap';

interface Props {
  type: string;
  props: Record<string, unknown>;
  lang: string;
  locales?: string[];
}

const { type, props, lang, locales } = Astro.props;

const isAllowed = !locales || locales.includes(lang);
const Component = componentMap[type];
---

{isAllowed && Component && (
  <Component {...props} lang={lang} />
)}
{isAllowed && !Component && (
  <div style="border:2px dashed red;padding:1rem;font-family:monospace;font-size:0.875rem;">
    Unknown component type: <strong>{type}</strong>
  </div>
)}
